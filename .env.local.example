# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── API base (leave empty for same-origin) ──
NEXT_PUBLIC_API_BASE=

# ── Database (add when ready) ──
# DATABASE_URL=postgresql://user:password@localhost:5432/ingeri

# ── Email provider (choose one when ready) ──
# RESEND_API_KEY=re_...
# SENDGRID_API_KEY=SG...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── Auth (add when ready) ──
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000
